from trasactions

# select customer_id, total_sales from (select customer_id, sum(amount) as total_sales, 
dense_rank() over (order by sum(amount) desc) as rn
from transactions group by customer_id)t
where rn <= 2


# select customer_id, sum(amount) as total_sales, 
dense_rank() over (order by sum(amount) desc) as rn
from transactions
group by customer_id

# select customer_id, count(transaction_id) as trans_count
from transactions
group by customer_id
having count(transaction_id) > 1

# COUNT(*)  counts null also
COUNT(customer_id) does not count nulls

# select customer_id, transaction_date as first_date from (select customer_id, transaction_date, 
row_number() over (partition by customer_id order by transaction_date) as rn
from transactions) t
where rn = 1

# select customer_id, transaction_id, transaction_date as latest_date from (select customer_id, transaction_id, transaction_date, 
row_number() over (partition by customer_id order by transaction_date desc) as rn
from transactions) t
where rn = 1






























