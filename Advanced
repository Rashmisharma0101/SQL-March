# Find customers who never placed an order.
customers and orders tables.

select customers.customerid from customers left join orders
on customers.customerid = orders.customerid
where orders.orderid is null

---------------------------------------------------------------------------------
# Rolling 3-month revenue for each customer
with cte1 as (select customerid, date_trunc('month', orderdate) as mn, sum(revenue) as total from orders group by customerid, month(orderdate))
select customerid, total, sum(total) over (partition by customerid order by mn rows between 2 preceding and current row)
as rolling_sum from cte1 order by customerid, mn

