# Compare revenue YoY per product using self-join or CTE.
with cte1 as (select productid, date_trunc('year', orderdate) as yr, sum(revenue) as total from sales group by productid, yr),
cte2 as (select productid, yr, total, lag(total) over (partition by productid order by yr asc)  as prev_total from cte1)
select productid, yr, total, coalesce((total-prev_total)* 100.0 /prev_total, 0) as yoypercentage from cte2
order by productid, yr
