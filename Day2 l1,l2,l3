Table: employees
| emp_id | name | department | salary |

Show name and department of all employees.

select name, department from employees

--------------------------------------------------------
Find employees whose salary is greater than 60000.
select name, salary from employees
where salary > 60000

--------------------------------------------------------
Find total salary per department.
select department, sum(salary) as total_salary from employees
group by department

--------------------------------------------------------
Find number of employees in each department.
select department, count(emp_id) as emp_count from employees
group by department

--------------------------------------------------------
Show employees sorted by salary (highest first).

select emp_id, name, salary from employees
order by salary desc

