-- Find customers who never placed an order
select customers.customer_id from customers
left join orders
on customers.customer_id = orders.customer_id
where orders.customer_id is null

-- second highest order amount
select amount from (
select amount, dense_rank() over (order by amount desc) as rn from orders) t
where rn = 2

-- running total of orders by date
select order_id, amount, sum(amount) over (order by order_date rows between unbounded preceding and current row) as running_total
from orders

-- remove duplicate orders
delete from orders o using
(select *, row_number() over (partition by customer_id, amount, order_date order by order_date desc)
as rn from orders) t
where o.customer_id = t.customer_id
and o.amount = t.amount
and o.order_date = t.order_date
and t.rn > 1

-- orders in last 30 days
select * from orders where order_date >= current_date - interval '30 days'

-- Data Validation
select * from orders where amount is null or order_date is null

