# Task: Top 1 product by total revenue per region.
product_id	region	sales_date	revenue

with cte1 as (select region, productid, sum(revenue) as total from sales group by region, productid),
cte2 as (select region, productid, total, rank() over (partition by region order by total desc) as rn from cte1)
select region, productid, total from cte2 where rn = 1

