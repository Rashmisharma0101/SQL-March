end as clean_date from orders


-- detect duplicate transactions
select cstomer_id, order_date, amount, count(*)
from orders
group by cstomer_id, order_date, amount
having count(*) > 1

-- keep latest record
with cte1 as(
select ctid, row_number() over (partition by customer_id, order_id order by order_date desc)
as rn
from orders)
delete from orders where ctid in (select ctid from cte1 where rn > 1)
# ctid is a PostgreSQL system column that uniquely identifies the physical row location. 
# I use it for safe deletion of duplicates when no primary key is available.

