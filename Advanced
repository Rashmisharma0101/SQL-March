# Calculate customer churn: customers who didn’t place order in last 3 months.
with cte1 as( select customerid, max(orderdate) as maxdate from orders group by customerid)
select * from cte1 where maxdate < currentdate - interval '3 months'

OR 
below one takes care of customers who never ordered

SELECT c.customerid
FROM customers c
LEFT JOIN orders o
    ON c.customerid = o.customerid
    AND o.orderdate >= CURRENT_DATE - INTERVAL '3 months'
WHERE o.customerid IS NULL;
