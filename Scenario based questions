-- Duplicate records in a table
select id, count(*) as cnts
from employee
group by id
having count(*) > 1

-- Second Highest salary from employee table
select max(sal) from employee where salary < (select max(salary) from employee)

-- find employees without department
select employees.empid, department.dept from employees left join department
on employees.deptid = department.deptid
where department.deptid is null

-- Total Revenue Per Product
select productid, sum(quantity*price) as revenue
from orders
group by productid

-- Top 3 Highest-Paid Employees
select empid, salary from employees
order by salary desc
limit 3

-- Customers Who Made Purchases but Never Returned Products 
select distinct customers.customer_id
from customers
join orders
on customers.cust_id = orders.cust_id
where customers.cust_id not in (select customer_id from returns)

--  Count of Orders Per Customer
select customer_id, count(order_id) as cnts
from orders
group by customer_id

-- All Employees Who Joined in 2023
select empid from employees
where extract (year from joining_date) = 2023

-- Average Order Value Per Customer
select customerid, avg(total_amount) as AOV
from orders
group by customerid

