-- Data Cleaning SQL Practice Set

-- find missing values
select * from orders where amount is null or order_date is null

-- Replace NULL amount with 0
select order_id, case when amount is null then 0 else amount end as amount
from orders

-- Remove extra spaces from customer_name
select trim(customer_name) as trimmed_customer_names
from customers

update customers
set customer_name = lower(customer_name)


-- Convert all email values to lowercase
select lower(email) as lowered_email from customers

update customers
set email = lower(email)

-- Remove duplicate rows based on:
customer_id, order_date

delete from orders using
(select customer_id, order_date, row_number() over (partition by customer_id, order_date order by order_date) 
as rn from orders) t
where t.customer_id = orders.customer_id
and t.order_date = orders.order_date
and t.rn > 1

-- Fix Date Format
select order_date, 
date_format(order_date, '%Y-%m-%d') as formatted_date from orders

-- Extract Clean Numbers
select regexp_replace(amount, '^[0-9]', '') as clean_amount from orders

